<?php

declare(strict_types=1);

final class Database
{
    private const HOST = '127.0.0.1';
    private const DB_NAME = 'banquetam_net';
    private const USER = 'root';
    private const PASSWORD = '';

    private static ?PDO $connection = null;

    public static function getConnection(bool $withoutDatabase = false): PDO
    {
        if (!$withoutDatabase && self::$connection instanceof PDO) {
            return self::$connection;
        }

        $dsn = $withoutDatabase
            ? 'mysql:host=' . self::HOST . ';charset=utf8mb4'
            : 'mysql:host=' . self::HOST . ';dbname=' . self::DB_NAME . ';charset=utf8mb4';

        $pdo = new PDO($dsn, self::USER, self::PASSWORD, [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
            PDO::ATTR_EMULATE_PREPARES => false,
        ]);

        if (!$withoutDatabase) {
            self::$connection = $pdo;
        }

        return $pdo;
    }
}

