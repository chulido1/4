                    'full_name' => $user['full_name'],
                    'phone' => $user['phone'],
                    'email' => $user['email'],
                    'role' => $user['role'],
                ];
                setFlash('success', 'Вы успешно вошли в систему.');
                redirect($user['role'] === 'admin' ? '/admin/index.php' : '/dashboard.php');
