<?php

declare(strict_types=1);

require_once __DIR__ . '/../config/app.php';
requireAdmin();

if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    redirect('/admin/index.php');
}

verifyCsrf();

$bookingId = filter_input(INPUT_POST, 'booking_id', FILTER_VALIDATE_INT);
$status = (string) ($_POST['status'] ?? '');
$returnQuery = preg_replace('/[^a-zA-Z0-9_=&%+\-.]/', '', (string) ($_POST['return_query'] ?? ''));

if (!$bookingId || !in_array($status, ['new', 'appointed', 'completed'], true)) {
    setFlash('danger', 'Не удалось изменить статус: переданы неверные данные.');
    redirect('/admin/index.php');
}

$bookingModel = new Booking(Database::getConnection());
$bookingModel->updateStatus($bookingId, $status);
setFlash('success', 'Статус заявки №' . $bookingId . ' изменен на «' . bookingStatusLabel($status) . '».');

header('Location: ' . BASE_URL . '/admin/index.php' . ($returnQuery !== '' ? '?' . $returnQuery : ''));
exit;

