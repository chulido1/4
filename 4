<?php

declare(strict_types=1);

final class Booking
{
    public function __construct(private PDO $pdo)
    {
    }

    public function create(int $userId, int $roomId, string $banquetDate, string $paymentMethod): int
    {
        $stmt = $this->pdo->prepare(
            'INSERT INTO bookings (user_id, room_id, banquet_date, payment_method, status)
             VALUES (:user_id, :room_id, :banquet_date, :payment_method, "new")'
        );
        $stmt->execute([
            'user_id' => $userId,
            'room_id' => $roomId,
            'banquet_date' => $banquetDate,
            'payment_method' => $paymentMethod,
        ]);

        return (int) $this->pdo->lastInsertId();
    }

    public function getRooms(): array
    {
        return $this->pdo->query('SELECT * FROM rooms ORDER BY id')->fetchAll();
    }

    public function getByUser(int $userId): array
    {
        $stmt = $this->pdo->prepare(
            'SELECT b.*, r.name AS room_name, r.type AS room_type,
                    rv.id AS review_id, rv.rating, rv.review_text
             FROM bookings b
             JOIN rooms r ON r.id = b.room_id
             LEFT JOIN reviews rv ON rv.booking_id = b.id
             WHERE b.user_id = :user_id
             ORDER BY b.created_at DESC'
        );
        $stmt->execute(['user_id' => $userId]);
        return $stmt->fetchAll();
    }

    public function getUserBooking(int $bookingId, int $userId): ?array
    {
        $stmt = $this->pdo->prepare(
            'SELECT b.*, r.name AS room_name
             FROM bookings b
             JOIN rooms r ON r.id = b.room_id
             WHERE b.id = :id AND b.user_id = :user_id
             LIMIT 1'
        );
        $stmt->execute(['id' => $bookingId, 'user_id' => $userId]);
        $booking = $stmt->fetch();
        return $booking ?: null;
    }

    public function countAll(array $filters): int
    {
        [$where, $params] = $this->buildFilter($filters);
        $stmt = $this->pdo->prepare(
            'SELECT COUNT(*) FROM bookings b
             JOIN users u ON u.id = b.user_id
             JOIN rooms r ON r.id = b.room_id ' . $where
        );
        $stmt->execute($params);
        return (int) $stmt->fetchColumn();
    }

    public function getAll(array $filters, string $sort, string $direction, int $limit, int $offset): array
    {
        $allowedSorts = [
            'created_at' => 'b.created_at',
            'banquet_date' => 'b.banquet_date',
            'status' => 'b.status',
            'full_name' => 'u.full_name',
            'room_name' => 'r.name',
        ];
        $sortSql = $allowedSorts[$sort] ?? 'b.created_at';
        $directionSql = strtoupper($direction) === 'ASC' ? 'ASC' : 'DESC';

        [$where, $params] = $this->buildFilter($filters);
        $sql = 'SELECT b.*, u.login, u.full_name, u.phone, u.email,
                       r.name AS room_name, r.type AS room_type
                FROM bookings b
                JOIN users u ON u.id = b.user_id
                JOIN rooms r ON r.id = b.room_id ' . $where .
               " ORDER BY {$sortSql} {$directionSql} LIMIT :limit OFFSET :offset";

        $stmt = $this->pdo->prepare($sql);
        foreach ($params as $key => $value) {
            $stmt->bindValue(':' . $key, $value);
        }
        $stmt->bindValue(':limit', $limit, PDO::PARAM_INT);
        $stmt->bindValue(':offset', $offset, PDO::PARAM_INT);
        $stmt->execute();
        return $stmt->fetchAll();
    }

    public function updateStatus(int $bookingId, string $status): bool
    {
        $stmt = $this->pdo->prepare(
            'UPDATE bookings SET status = :status, updated_at = CURRENT_TIMESTAMP WHERE id = :id'
        );
        return $stmt->execute(['status' => $status, 'id' => $bookingId]);
    }

    private function buildFilter(array $filters): array
    {
        $conditions = [];
        $params = [];

        if (!empty($filters['status']) && in_array($filters['status'], ['new', 'appointed', 'completed'], true)) {
            $conditions[] = 'b.status = :status';
            $params['status'] = $filters['status'];
        }

        if (!empty($filters['room_id']) && ctype_digit((string) $filters['room_id'])) {
            $conditions[] = 'b.room_id = :room_id';
            $params['room_id'] = (int) $filters['room_id'];
        }

        if (!empty($filters['search'])) {
            $conditions[] = '(u.full_name LIKE :search OR u.login LIKE :search OR u.phone LIKE :search)';
            $params['search'] = '%' . trim((string) $filters['search']) . '%';
        }

        return [$conditions ? 'WHERE ' . implode(' AND ', $conditions) : '', $params];
    }
}

