<?php

declare(strict_types=1);

require_once __DIR__ . '/config/app.php';
requireLogin();

if ($_SERVER['REQUEST_METHOD'] !== 'POST' || isAdmin()) {
    redirect('/dashboard.php');
}

verifyCsrf();

$bookingId = filter_input(INPUT_POST, 'booking_id', FILTER_VALIDATE_INT);
$rating = filter_input(INPUT_POST, 'rating', FILTER_VALIDATE_INT);
$text = trim((string) ($_POST['review_text'] ?? ''));

if (!$bookingId || !$rating || $rating < 1 || $rating > 5 || mb_strlen($text) < 3 || mb_strlen($text) > 1000) {
    setFlash('danger', 'Проверьте оценку и текст отзыва.');
    redirect('/dashboard.php');
}

$pdo = Database::getConnection();
$bookingModel = new Booking($pdo);
$reviewModel = new Review($pdo);
$booking = $bookingModel->getUserBooking($bookingId, (int) currentUser()['id']);

if (!$booking || $booking['status'] !== 'completed') {
    setFlash('danger', 'Отзыв можно оставить только после завершения банкета.');
    redirect('/dashboard.php');
}

if ($reviewModel->existsForBooking($bookingId)) {
    setFlash('warning', 'Отзыв по этой заявке уже был оставлен.');
    redirect('/dashboard.php');
}

$reviewModel->create($bookingId, (int) currentUser()['id'], $rating, $text);
setFlash('success', 'Спасибо! Ваш отзыв сохранен.');
redirect('/dashboard.php');

