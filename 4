$rooms = $bookingModel->getRooms();
$errors = [];
$values = [
    'room_id' => '',
    'banquet_date' => '',
    'payment_method' => '',
];

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verifyCsrf();
    $values['room_id'] = trim((string) ($_POST['room_id'] ?? ''));
    $values['banquet_date'] = trim((string) ($_POST['banquet_date'] ?? ''));
    $values['payment_method'] = trim((string) ($_POST['payment_method'] ?? ''));

    $roomIds = array_map(static fn(array $room): int => (int) $room['id'], $rooms);
    if (!ctype_digit($values['room_id']) || !in_array((int) $values['room_id'], $roomIds, true)) {
        $errors['room_id'] = 'Выберите помещение из списка.';
    }

    $date = DateTimeImmutable::createFromFormat('!d.m.Y', $values['banquet_date']);
    $dateErrors = DateTimeImmutable::getLastErrors();
    $dateIsValid = $date && ($dateErrors === false || ($dateErrors['warning_count'] === 0 && $dateErrors['error_count'] === 0));

    if (!$dateIsValid) {
        $errors['banquet_date'] = 'Введите дату в формате ДД.ММ.ГГГГ.';
    } elseif ($date < new DateTimeImmutable('today')) {
        $errors['banquet_date'] = 'Дата банкета не может быть в прошлом.';
    }

    if (!in_array($values['payment_method'], ['cash', 'card', 'transfer'], true)) {
        $errors['payment_method'] = 'Выберите способ оплаты.';
    }

    if (!$errors && $date) {
        $bookingModel->create(
            (int) currentUser()['id'],
            (int) $values['room_id'],
            $date->format('Y-m-d'),
            $values['payment_method']
        );
        setFlash('success', 'Заявка создана и отправлена администратору.');
        redirect('/dashboard.php');
    }
}

