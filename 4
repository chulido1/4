<?php

declare(strict_types=1);

require_once __DIR__ . '/config/app.php';

if (isLoggedIn()) {
    redirect(isAdmin() ? '/admin/index.php' : '/dashboard.php');
}

$errors = [];
$values = [
    'login' => '',
    'full_name' => '',
    'phone' => '',
    'email' => '',
];

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    verifyCsrf();

    foreach ($values as $key => $unused) {
        $values[$key] = trim((string) ($_POST[$key] ?? ''));
    }
    $password = (string) ($_POST['password'] ?? '');
    $passwordConfirm = (string) ($_POST['password_confirm'] ?? '');

    if (!preg_match('/^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d]{6,}$/', $values['login'])) {
        $errors['login'] = 'Логин должен содержать латинские буквы и цифры, минимум 6 символов.';
    }

    if (mb_strlen($password) < 8) {
        $errors['password'] = 'Пароль должен содержать не менее 8 символов.';
    }

    if ($password !== $passwordConfirm) {
        $errors['password_confirm'] = 'Пароли не совпадают.';
    }

    if (mb_strlen($values['full_name']) < 5) {
        $errors['full_name'] = 'Введите полное ФИО.';
    }

    if (!preg_match('/^[+\d][\d\s()\-]{9,19}$/u', $values['phone'])) {
        $errors['phone'] = 'Введите корректный номер телефона.';
    }

    if (!filter_var($values['email'], FILTER_VALIDATE_EMAIL)) {
        $errors['email'] = 'Введите корректный e-mail.';
    }

    try {
        $pdo = Database::getConnection();
        $userModel = new User($pdo);

        if (!$errors && $userModel->findByLogin($values['login'])) {
            $errors['login'] = 'Пользователь с таким логином уже существует.';
        }

        if (!$errors) {
            $userModel->create([
                ...$values,
                'password' => $password,
            ]);
            setFlash('success', 'Регистрация выполнена. Теперь войдите в систему.');
            redirect('/login.php');
        }
    } catch (PDOException $exception) {
        $errors['general'] = 'Не удалось сохранить пользователя. Проверьте подключение к базе данных.';
    }
}

$pageTitle = 'Регистрация';
require __DIR__ . '/includes/header.php';
