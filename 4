function redirect(string $path): never
{
    header('Location: ' . BASE_URL . $path);
    exit;
}

function setFlash(string $type, string $message): void
{
    $_SESSION['flash'] = ['type' => $type, 'message' => $message];
}

function getFlash(): ?array
{
    $flash = $_SESSION['flash'] ?? null;
    unset($_SESSION['flash']);
    return $flash;
}

function formatDateRu(?string $date): string
{
    if (!$date) {
        return '—';
    }

    $timestamp = strtotime($date);
    return $timestamp ? date('d.m.Y', $timestamp) : '—';
}

function bookingStatusLabel(string $status): string
{
    return match ($status) {
        'new' => 'Новая',
        'appointed' => 'Банкет назначен',
        'completed' => 'Банкет завершен',
        default => 'Неизвестно',
    };
}

function bookingStatusClass(string $status): string
{
    return match ($status) {
        'new' => 'status-new',
        'appointed' => 'status-appointed',
        'completed' => 'status-completed',
        default => '',
    };
}

function paymentLabel(string $payment): string
